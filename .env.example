# Server
PORT=8000
NODE_ENV=development
# Plusieurs origines séparées par des virgules (front web + Expo web sur le LAN si besoin)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Database — local Postgres : les deux URLs identiques
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/taskflow?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/taskflow?schema=public"

# Supabase (copier depuis le dashboard, ne pas committer le vrai mot de passe) :
# 1) Transaction pooling (port 6543) → DATABASE_URL
# 2) Direct connection (db.<ref>.supabase.co:5432) → DIRECT_URL
# Encoder le mot de passe dans l’URL si besoin (! → %21, @ dans le mot de passe interdit, etc.)
# Exemples (remplacer YOUR_PASSWORD et vérifier l’hôte pooler dans Supabase) :
# DATABASE_URL="postgresql://postgres.uwwpyxlkudrfwajxynat:YOUR_PASSWORD@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?sslmode=require"
# DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.uwwpyxlkudrfwajxynat.supabase.co:5432/postgres?sslmode=require"

# JWT
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

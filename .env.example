# Server
PORT=8000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Database
# Local Postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/taskflow?schema=public"

# Supabase + Render (IPv4) : une seule variable.
# Dans Supabase → Settings → Database → Connection string :
# choisir « Session pooler » / compatible IPv4 (hôte *.pooler.supabase.com, souvent port 5432).
# Ne pas utiliser « Direct connection » (db.*.supabase.co) pour Render : P1001 depuis leurs serveurs.
# Encoder ! dans le mot de passe : %21
# Exemple (mot de passe fictif) :
# DATABASE_URL="postgresql://postgres.uwwpyxlkudrfwajxynat:Mot%21depasse@aws-1-eu-west-3.pooler.supabase.com:5432/postgres?sslmode=require"

# JWT
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
